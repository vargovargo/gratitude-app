# ─────────────────────────────────────────────────────────────────────────────
# Gratitude Text App — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Twilio credentials (required)
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# Server
PORT=3000
NODE_ENV=development   # Set to "production" to enable Twilio signature validation

# Scheduling (24-hour clock, all times in TIMEZONE below)
MORNING_HOUR=8         # Hour to send morning prompts  (default: 8  = 8:00 AM)
EVENING_HOUR=19        # Hour to send evening reminders (default: 19 = 7:00 PM)
TIMEZONE=America/New_York

# Admin API security
# Set a strong random string here — required to call /members, /responses, etc.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=your-secret-admin-token-here

# Signup interest form — admin notification
# When someone submits the /signup interest form, a text is sent to this number.
# E.164 format, e.g. +15551234567
ADMIN_PHONE=+15551234567
