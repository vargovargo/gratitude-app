# ─────────────────────────────────────────────────────────────────────────────
# Gratitude Text App — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Twilio credentials (required)
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Sending number — choose one of the two options below:
#
# Option A: Toll-free number via a Messaging Service (recommended for toll-free)
#   Create a Messaging Service in the Twilio console, add your toll-free number
#   to it, then paste the Messaging Service SID here.  When this is set,
#   TWILIO_PHONE_NUMBER is ignored for outbound sends.
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Option B: Direct phone number (standard long-code or short-code)
#   Comment out TWILIO_MESSAGING_SERVICE_SID above and set your E.164 number.
TWILIO_PHONE_NUMBER=+15551234567

# Server
PORT=3000
NODE_ENV=development   # Set to "production" to enable Twilio signature validation

# Scheduling (24-hour clock, all times in TIMEZONE below)
MORNING_HOUR=8         # Hour to send morning prompts  (default: 8  = 8:00 AM)
EVENING_HOUR=19        # Hour to send evening reminders (default: 19 = 7:00 PM)
TIMEZONE=America/New_York

# Admin API security
# Set a strong random string here — required to call /members, /responses, etc.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=your-secret-admin-token-here
